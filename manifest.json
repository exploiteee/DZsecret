{
  "name": "DZsecret",
  "version": "2.0.19",
  "manifest_version": 3,
  "description": "DZsecret - First Algerian browser extension for detecting API keys, tokens, passwords, and hidden endpoints in webpages.",
  "permissions": [
    "tabs",
    "storage",
    "unlimitedStorage"
  ],
  "content_scripts": [{
    "matches": [
      "https://*/*",
      "http://*/*",
      "file://*"
    ],
    "js": ["content.js"]
  }],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  }
}
